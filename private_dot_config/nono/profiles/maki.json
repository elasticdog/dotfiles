{
  "extends": ["default"],
  "meta": {
    "name": "maki"
  },
  "groups": {
    "include": ["git_config"]
  },
  "workdir": {
    "access": "readwrite"
  },
  "filesystem": {
    "allow": [
      "$HOME/.cache/maki",
      "$HOME/.config/maki",
      "$HOME/.local/state/maki"
    ],
    "read": []
  },
  "diagnostics": {
    "suppress_system_services": ["user-preference-read"]
  }
}
